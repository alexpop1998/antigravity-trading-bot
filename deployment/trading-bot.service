[Unit]
Description=Institutional Trading Terminal Backend
After=network.target

[Service]
User=YOUR_VPS_USERNAME
Group=YOUR_VPS_USERNAME
WorkingDirectory=/home/YOUR_VPS_USERNAME/trading-terminal/backend
Environment="PATH=/home/YOUR_VPS_USERNAME/trading-terminal/venv/bin"
# Load environment variables from our .env file
EnvironmentFile=/home/YOUR_VPS_USERNAME/trading-terminal/backend/.env
ExecStart=/home/YOUR_VPS_USERNAME/trading-terminal/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --workers 4

Restart=always
RestartSec=5
StandardOutput=append:/var/log/trading-bot.log
StandardError=append:/var/log/trading-bot.error.log

[Install]
WantedBy=multi-user.target
